# ========================================
# 胸影智诊V2.0 - Git 忽略配置
# 位置：项目根目录（与 .git 同级）
# ========================================

# ==================== 依赖目录（大文件，不应入库）====================
node_modules/
package-lock.json
venv/
.venv/
env/

# ==================== Python ====================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.eggs/

# ==================== 数据库文件 ====================
*.db
*.db-shm
*.db-wal

# ==================== 环境变量/密钥 ====================
.env
.env.local
.env.*.local

# ==================== AI 模型权重（大文件）====================
**/*.pth
**/*.pt
**/*.onnx
**/*.pkl
# 保留空目录结构
!backend/weights/.gitkeep

# ==================== 运行时静态文件（上传影像/热力图/报告）====================
backend/static/uploads/
backend/static/heatmaps/
backend/static/reports/
backend/static/images/
!backend/static/uploads/.gitkeep
!backend/static/heatmaps/.gitkeep
!backend/static/reports/.gitkeep
!backend/static/images/.gitkeep

# ==================== 前端构建产物 ====================
frontend/node_modules/
frontend/dist/
frontend/.vite/

# ==================== IDE / 编辑器 ====================
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.code-workspace

# ==================== 操作系统 ====================
.DS_Store
Thumbs.db
desktop.ini

# ==================== 日志与临时文件 ====================
*.log
logs/
*.tmp
*.bak
init_out.txt
glass-dashboard.html

# ==================== 生成的文档（PPT/PDF等，通常另存或用Release管理）====================
*.pptx
*.pdf

胸影智诊V2.0_*
USAGE_GUIDE.md
generate_*.js

# ==================== 训练数据集（可选，按需取消注释）====================
# medical_xray_3060_train/
